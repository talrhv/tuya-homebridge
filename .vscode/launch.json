{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Homebridge",
      "skipFiles": ["<node_internals>/**"],
      // זה הנתיב לקובץ ה-JS האמיתי ב-nvm4w
      "program": "C:/nvm4w/nodejs/node_modules/homebridge/bin/homebridge",
      "args": ["-D", "-P", ".", "-U", "./config"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "env": {
        "NODE_ENV": "development"
      }
    }
  ]
}
